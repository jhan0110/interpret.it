{$PUBLIC_DOMAIN} {
	handle /ws/* {
		reverse_proxy gateway:8000
	}

	# MinIO path-style bucket access for presigned audio URLs. The
	# bucket name `interpretit` appears in the URL path (MinIO defaults
	# to path-style). The S3v4 signature on the presigned URL was
	# computed against PUBLIC_DOMAIN; MinIO validates the signature
	# using whatever Host header it sees. We hardcode that header to
	# {$PUBLIC_DOMAIN} (Caddy env-substitution at config load) because
	# the request-time {host} placeholder doesn't reliably override
	# reverse_proxy's default of rewriting Host to the upstream.
	handle /interpretit/* {
		reverse_proxy minio:9000 {
			header_up Host {$PUBLIC_DOMAIN}
		}
	}

	@gateway_routes path /sessions* /learners* /internal* /health
	handle @gateway_routes {
		basicauth {
			{$BASIC_AUTH_USER} {$BASIC_AUTH_PASSWORD_HASH}
		}
		reverse_proxy gateway:8000
	}

	handle {
		basicauth {
			{$BASIC_AUTH_USER} {$BASIC_AUTH_PASSWORD_HASH}
		}
		reverse_proxy frontend:3000
	}
}
