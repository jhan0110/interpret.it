{$PUBLIC_DOMAIN} {
	handle /ws/* {
		reverse_proxy gateway:8000
	}

	# MinIO path-style bucket access for presigned audio URLs. The
	# bucket name `interpretit` appears in the URL path. The gateway
	# signs URLs against the internal minio:9000 host (see
	# storage.py::signed_get_url) and rewrites only the public origin
	# into the URL afterwards. Caddy's default reverse_proxy behaviour
	# (rewrite Host to upstream's hostport) is exactly what we want
	# here — MinIO sees Host: minio:9000 which matches the signed host.
	handle /interpretit/* {
		reverse_proxy minio:9000
	}

	@gateway_routes path /sessions* /learners* /internal* /health
	handle @gateway_routes {
		basicauth {
			{$BASIC_AUTH_USER} {$BASIC_AUTH_PASSWORD_HASH}
		}
		reverse_proxy gateway:8000
	}

	handle {
		basicauth {
			{$BASIC_AUTH_USER} {$BASIC_AUTH_PASSWORD_HASH}
		}
		reverse_proxy frontend:3000
	}
}
