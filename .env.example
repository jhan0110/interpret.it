# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit a populated copy.
#
# Required for any deployment (local or remote):
#   - OPENROUTER_API_KEY        (Claude + TTS via OpenRouter)
#   - GROQ_API_KEY              (Whisper ASR, free tier OK)
#   - PUBLIC_DOMAIN             (the domain Caddy serves)
#   - BASIC_AUTH_USER + BASIC_AUTH_PASSWORD_HASH (basicauth gate)
#   - INTERNAL_RPC_SECRET       (gateway ↔ analysis bearer token)
#   - CORS_ALLOW_ORIGINS        (the https URL the frontend is served from)

# ---- Operating mode ----
# 0 = real APIs; 1 = mock pipeline (silent audio, fixed responses).
USE_MOCKS=0

# ---- LLM + TTS (OpenRouter, OpenAI-compatible) ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CLAUDE_MODEL=anthropic/claude-sonnet-4-6

TTS_PROVIDER=openai
OPENAI_TTS_MODEL=openai/gpt-audio-mini
OPENAI_TTS_VOICE=alloy

# ---- ASR (Groq Whisper) ----
GROQ_API_KEY=
WHISPER_PROVIDER=groq
GROQ_WHISPER_MODEL=whisper-large-v3

# ---- Optional legacy fallbacks ----
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_FEEDBACK_VOICE=EXAVITQu4vr4xnSDxMaL

# ---- Public surface (Caddy + basicauth) ----
# PUBLIC_DOMAIN is what the cert is issued for + the hostname Caddy
# serves. For local dry-run: interpretit.local + /etc/hosts entry.
PUBLIC_DOMAIN=interpretit.local
BASIC_AUTH_USER=admin

# Generate the password hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext '<your-password>'
#
# Then ESCAPE every `$` as `$$` here so docker compose passes the bcrypt
# value through unmodified (compose treats single `$` as variable
# reference). Example for plaintext 'demo-pass-replace-me':
#   BASIC_AUTH_PASSWORD_HASH=$$2a$$14$$twfBrrn6n.12nvhVanSi8uU6xLxZPjvsBWXwv4xjRgDIANWzIaMqu
BASIC_AUTH_PASSWORD_HASH=

# Browser-facing origin (frontend + same-origin gateway). Must match
# the URL Caddy serves on. Used by the gateway's CORS allowlist.
CORS_ALLOW_ORIGINS=https://interpretit.local

# MinIO presigned-URL host. MUST be the public origin Caddy serves on,
# not the internal docker hostname — these URLs are sent to the browser
# and the SigV4 signature is bound to this host. If unset, the browser
# would receive URLs pointing at the gateway's internal MinIO endpoint,
# which it cannot reach.
MINIO_PUBLIC_ENDPOINT=https://interpretit.local

# ---- Internal RPC (gateway ↔ analysis bearer) ----
# Generate with: openssl rand -hex 32
INTERNAL_RPC_SECRET=

# ---- Rate limits (defaults are dev-friendly; tighten in prod) ----
# ATTEMPT_QUOTA_DAILY=100
# MAX_DAILY_USD=5
